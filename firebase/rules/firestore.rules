rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any signed-in user can manage CMS data. In Firebase Console: Authentication →
    // Settings → disable "public sign-up" and only add staff accounts.
    function isAdmin() {
      return request.auth != null;
    }

    // Only for create/update. On delete, request.resource is not set — do not use this on delete.
    function imageUrlOk() {
      return !('imageUrl' in request.resource.data)
        || (request.resource.data.imageUrl is string
            && request.resource.data.imageUrl.size() < 650000);
    }

    function validInquiry() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && d.name is string && d.name.size() > 0 && d.name.size() < 200
        && d.email is string && d.email.size() < 320
        && d.message is string && d.message.size() > 0 && d.message.size() < 10000
        && (!('phone' in d) || (d.phone is string && d.phone.size() < 40))
        && (!('subject' in d) || (d.subject is string && d.subject.size() < 300))
        && (!('read' in d) || d.read == false);
    }

    match /blogPosts/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update: if isAdmin() && imageUrlOk();
      allow delete: if isAdmin();
    }

    match /galleryItems/{itemId} {
      allow read: if true;
      allow create, update: if isAdmin() && imageUrlOk();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && imageUrlOk();
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if validInquiry();
      allow read, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if docId == 'site';
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
